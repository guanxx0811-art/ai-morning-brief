# ===== AI 晨报 配置模板 =====
# 使用方法：复制本文件为 .env，填入真实值
#   copy backend\.env.example backend\.env   (PowerShell)
# 密钥不要硬编码进源码，也不要把 .env 提交到代码仓库。

# 智谱开放平台 API Key（https://open.bigmodel.cn/usercenter/apikeys）
ZHIPU_API_KEY=44abd690d927419ead3249b7c2cf62da.v7MGF0KZYGaBZOeD

# 调用的模型 ID（已核对官方文档，glm-4.6 为当前主力且支持搜索）
MODEL_NAME=glm-4.6

# 服务监听地址与端口
# HOST 用 0.0.0.0 表示监听所有网卡，这样同一局域网的手机能用本机 IP 访问
HOST=0.0.0.0
PORT=8000
